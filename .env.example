# Copy this file to .env and fill in real values for production.
# NEVER commit .env to source control.

SITE_NAME=CENTRE MEDICAL DONS DE SOINS
SITE_URL=https://example.com
SITE_LOGO_URL=
PAYMENT_NUMBER=681629394
CUSTOMER_SERVICE_NUMBER=+237678612733

# Database
DB_TYPE=mysql
# For hosted deployments, set DB_FILE to a writable path such as /var/data/clinic.db
# DB_FILE=/var/data/clinic.db
# Railway MySQL can be auto-mapped from MYSQLHOST, MYSQLDATABASE,
# MYSQLUSER, and MYSQLPASSWORD. Set these only if needed.
# DB_HOST=localhost
# DB_NAME=dondesionc_clinic
# DB_USER=your_db_user
# DB_PASS=your_db_password
# AUTO_SETUP_DB=1

# Security — generate with: php -r "echo bin2hex(random_bytes(32));"
ENCRYPTION_KEY=your-64-char-hex-key-here

# CinetPay payment gateway
CINERPAY_API_KEY=
CINERPAY_SITE_ID=

# SMTP (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_PORT=587
SMTP_SECURE=tls
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME=CENTRE MEDICAL DONS DE SOINS

# Realtime email API (optional alternative to SMTP)
BREVO_API_KEY=

# Realtime SMS and voice gateway (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VOICE_URL=

# Payment approval and verification
PAYMENT_PINCODE=
PAYMENT_DEV_SHOW_CODE=0
