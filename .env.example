# Copy this file to .env and fill in real values for production.
# NEVER commit .env to source control.

SITE_NAME=Dons de sions
PAYMENT_NUMBER=681629394
CUSTOMER_SERVICE_NUMBER=+237678612733

# Database
DB_TYPE=mysql
# For hosted deployments, set DB_FILE to a writable path such as /var/data/clinic.db
# DB_FILE=/var/data/clinic.db
# Railway MySQL can be auto-mapped from MYSQLHOST, MYSQLDATABASE,
# MYSQLUSER, and MYSQLPASSWORD. Set these only if needed.
# DB_HOST=localhost
# DB_NAME=dondesionc_clinic
# DB_USER=your_db_user
# DB_PASS=your_db_password
# AUTO_SETUP_DB=1

# Security — generate with: php -r "echo bin2hex(random_bytes(32));"
ENCRYPTION_KEY=ddsawc1232018-

# CinetPay payment gateway
CINERPAY_API_KEY=
CINERPAY_SITE_ID=

# SMTP (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_PORT=587
